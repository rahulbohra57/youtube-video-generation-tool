{
  "functions": {
    "api/**/*.py": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" },
    {
      "source": "/admin/metrics/:path*",
      "destination": "/api/admin/metrics/:path*"
    },
    {
      "source": "/webhook/telegram",
      "destination": "/api/webhook/telegram"
    },
    {
      "source": "/webhook/telegram/stories",
      "destination": "/api/webhook/stories"
    },
    {
      "source": "/auth/youtube/callback",
      "destination": "/api/auth/youtube_callback"
    },
    {
      "source": "/auth/youtube/stories/callback",
      "destination": "/api/auth/stories_callback"
    },
    {
      "source": "/auth/youtube/stories",
      "destination": "/api/auth/stories"
    },
    {
      "source": "/auth/youtube",
      "destination": "/api/auth/youtube"
    }
  ]
}
